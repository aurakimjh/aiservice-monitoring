{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" },
    { "name": "DS_TEMPO",      "label": "Tempo",      "type": "datasource", "pluginId": "tempo" }
  ],
  "title": "AI Service Overview — 전체 서비스 현황",
  "uid": "aiservice-overview",
  "tags": ["ai", "overview", "slo"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "description": "AI 서비스 전체 상태를 한눈에 파악하는 Executive 대시보드. E2E 레이턴시, 에러율, 레이어별 기여도, SLO 달성률을 표시합니다.",
  "templating": {
    "list": [
      {
        "name": "env", "label": "환경",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(aiservice_http_server_request_duration_bucket, env)",
        "includeAll": false
      }
    ]
  },
  "panels": [
    {
      "id": 1, "gridPos": { "x": 0, "y": 0, "w": 3, "h": 4 },
      "type": "stat", "title": "E2E P95 레이턴시",
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": { "mode": "absolute", "steps": [
            { "value": null,  "color": "green" },
            { "value": 3000,  "color": "yellow" },
            { "value": 5000,  "color": "red" }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(aiservice_http_server_request_duration_bucket[5m])) by (le))",
        "legendFormat": "P95"
      }]
    },
    {
      "id": 2, "gridPos": { "x": 3, "y": 0, "w": 3, "h": 4 },
      "type": "stat", "title": "에러율",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [
            { "value": null,   "color": "green" },
            { "value": 0.005,  "color": "yellow" },
            { "value": 0.01,   "color": "red" }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [{
        "expr": "sum(rate(aiservice_http_server_request_duration_count{http_status_code=~\"5..\"}[5m])) / sum(rate(aiservice_http_server_request_duration_count[5m]))",
        "legendFormat": "에러율"
      }]
    },
    {
      "id": 3, "gridPos": { "x": 6, "y": 0, "w": 3, "h": 4 },
      "type": "stat", "title": "TTFT P95",
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": { "mode": "absolute", "steps": [
            { "value": null,  "color": "green" },
            { "value": 2000,  "color": "yellow" },
            { "value": 3000,  "color": "red" }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(aiservice_llm_time_to_first_token_bucket[5m])) by (le))",
        "legendFormat": "TTFT P95"
      }]
    },
    {
      "id": 4, "gridPos": { "x": 9, "y": 0, "w": 3, "h": 4 },
      "type": "stat", "title": "처리량 (RPS)",
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [{
        "expr": "sum(rate(aiservice_http_server_request_duration_count[5m]))",
        "legendFormat": "RPS"
      }]
    },
    {
      "id": 5, "gridPos": { "x": 12, "y": 0, "w": 3, "h": 4 },
      "type": "stat", "title": "GPU VRAM",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [
            { "value": null, "color": "green" },
            { "value": 75,   "color": "yellow" },
            { "value": 90,   "color": "red" }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{
        "expr": "avg(aiservice_gpu_memory_used / (aiservice_gpu_memory_used + aiservice_gpu_memory_free)) * 100",
        "legendFormat": "VRAM %"
      }]
    },
    {
      "id": 6, "gridPos": { "x": 15, "y": 0, "w": 3, "h": 4 },
      "type": "stat", "title": "가드레일 차단율",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [
            { "value": null,  "color": "green" },
            { "value": 0.05,  "color": "yellow" },
            { "value": 0.10,  "color": "red" }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{
        "expr": "sum(rate(aiservice_guardrail_block_total[5m])) / sum(rate(aiservice_guardrail_request_total[5m]))",
        "legendFormat": "차단율"
      }]
    },
    {
      "id": 7, "gridPos": { "x": 18, "y": 0, "w": 3, "h": 4 },
      "type": "stat", "title": "Semantic Cache 히트율",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [
            { "value": null,  "color": "red" },
            { "value": 0.20,  "color": "yellow" },
            { "value": 0.40,  "color": "green" }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{
        "expr": "sum(rate(aiservice_vectordb_cache_hit_total[5m])) / (sum(rate(aiservice_vectordb_cache_hit_total[5m])) + sum(rate(aiservice_vectordb_cache_miss_total[5m])))",
        "legendFormat": "Cache Hit Rate"
      }]
    },
    {
      "id": 8, "gridPos": { "x": 21, "y": 0, "w": 3, "h": 4 },
      "type": "stat", "title": "외부 API 에러율",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [
            { "value": null,  "color": "green" },
            { "value": 0.02,  "color": "yellow" },
            { "value": 0.05,  "color": "red" }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{
        "expr": "sum(rate(aiservice_external_api_error_total[5m])) / sum(rate(aiservice_external_api_request_total[5m]))",
        "legendFormat": "외부 API 에러율"
      }]
    },
    {
      "id": 10, "gridPos": { "x": 0, "y": 4, "w": 16, "h": 8 },
      "type": "timeseries", "title": "E2E 요청 레이턴시 (P50 / P95 / P99)",
      "description": "전체 요청 레이턴시 추이. SLO 목표선(P95 < 5,000ms) 표시.",
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": { "mode": "absolute", "steps": [
            { "value": null, "color": "green" },
            { "value": 5000, "color": "red" }
          ]}
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max", "p95"] }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(aiservice_http_server_request_duration_bucket[5m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(aiservice_http_server_request_duration_bucket[5m])) by (le))",
          "legendFormat": "P95 (SLO: 5000ms)"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(aiservice_http_server_request_duration_bucket[5m])) by (le))",
          "legendFormat": "P99"
        }
      ]
    },
    {
      "id": 11, "gridPos": { "x": 16, "y": 4, "w": 8, "h": 8 },
      "type": "barchart", "title": "레이어별 평균 레이턴시 기여도",
      "description": "각 레이어가 E2E 레이턴시에서 차지하는 평균 비중. 가장 긴 바가 병목.",
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "options": { "orientation": "horizontal", "groupWidth": 0.7 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(aiservice_guardrail_validation_duration_bucket[5m])) by (le))", "legendFormat": "가드레일" },
        { "expr": "histogram_quantile(0.50, sum(rate(aiservice_agent_chain_step_duration_bucket[5m])) by (le))", "legendFormat": "에이전트 체인" },
        { "expr": "histogram_quantile(0.50, sum(rate(aiservice_vectordb_search_duration_bucket[5m])) by (le))", "legendFormat": "벡터 검색" },
        { "expr": "histogram_quantile(0.50, sum(rate(aiservice_llm_time_to_first_token_bucket[5m])) by (le))", "legendFormat": "LLM TTFT" },
        { "expr": "histogram_quantile(0.50, sum(rate(aiservice_external_api_request_duration_bucket[5m])) by (le))", "legendFormat": "외부 API" }
      ]
    },
    {
      "id": 20, "gridPos": { "x": 0, "y": 12, "w": 24, "h": 7 },
      "type": "alertlist", "title": "현재 활성 Alert",
      "description": "Prometheus Alert Manager에서 수신된 활성 알람 목록.",
      "options": {
        "alertInstanceLabelFilter": "",
        "alertName": "",
        "dashboardAlerts": false,
        "datasource": "-- Grafana --",
        "groupBy": ["alertname", "severity"],
        "groupMode": "tags",
        "maxItems": 20,
        "sortOrder": 1,
        "stateFilter": { "firing": true, "pending": true }
      }
    }
  ]
}
