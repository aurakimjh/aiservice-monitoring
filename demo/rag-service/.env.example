# ── OTel Collector 엔드포인트 ──────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ── 서비스 설정 ─────────────────────────────────────────────
SERVICE_NAME=rag-demo-service
DEPLOYMENT_ENV=development

# ── LLM API 설정 ───────────────────────────────────────────
# Mock 모드에서는 API 키 불필요 (기본값: true)
MOCK_MODE=true
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── 벡터 검색 설정 ──────────────────────────────────────────
VECTOR_TOP_K=3
SIMILARITY_THRESHOLD=0.3
