# ═══════════════════════════════════════════════════════════════
# AITOP Docker Environment Variables
#
# Usage:
#   cp .env.example .env
#   vi .env                   # 비밀번호 등 필수 항목 변경
#   docker compose -f ../../docker-compose.production.yaml --env-file .env up -d
# ═══════════════════════════════════════════════════════════════

# ── Collection Server ─────────────────────────────────────────
AITOP_LISTEN_ADDR=:8080
AITOP_GRPC_ADDR=:50051
AITOP_LOG_LEVEL=info
AITOP_STORAGE_TYPE=local
AITOP_STORAGE_PATH=/var/aitop/data
AITOP_STORAGE_RETENTION_DAYS=30

# JWT Secret (반드시 변경 — 최소 32자)
AITOP_JWT_SECRET=change-me-to-a-secure-random-string-min-32-chars

# Prometheus / Jaeger 연결 (docker-compose 내부 네트워크)
AITOP_PROMETHEUS_URL=http://prometheus:9090
AITOP_JAEGER_URL=http://jaeger:16686

# ── Frontend ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://collection-server:8080/api/v1
NODE_ENV=production

# ── Prometheus ────────────────────────────────────────────────
PROMETHEUS_RETENTION=30d
PROMETHEUS_RETENTION_SIZE=10GB

# ── Jaeger ────────────────────────────────────────────────────
BADGER_SPAN_STORE_TTL=168h

# ── PostgreSQL (사용 시) ──────────────────────────────────────
# AITOP_DB_URL=postgres://aitop:your-password@postgres:5432/aitop?sslmode=disable
# POSTGRES_DB=aitop
# POSTGRES_USER=aitop
# POSTGRES_PASSWORD=your-secure-password
